{
  "manifest_version": 2,
  "name": "Aqbobek AI Agent",
  "version": "1.0.0",
  "description": "AI-агент для автоматизации работы в КМИС Дамумед — голосовое заполнение форм и управление расписанием",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_icon": "icons/icon48.png",
    "default_title": "Aqbobek AI Agent"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "optional_permissions": [
    "microphone"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "web_accessible_resources": [
    "panel.html",
    "panel.css",
    "panel.js"
  ]
}